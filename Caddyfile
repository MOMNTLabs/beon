{
    admin off
    auto_https off
}

:{$PORT:8080} {
    root * /app
    encode zstd gzip
    @legacyVendas path /vendas /vendas/ /vendas.php
    redir @legacyVendas /home 308
    redir /index.php / 308
    redir /home.php /home 308
    redir /account-settings.php /account-settings 308
    redir /workspace-settings.php /workspace-settings 308
    redir /privacidade.php /privacidade 308
    redir /termos.php /termos 308
    redir /cookies.php /cookies 308
    redir /dados.php /dados 308

    @hasPhpFile file {path}.php
    rewrite @hasPhpFile {path}.php

    php_server
}
